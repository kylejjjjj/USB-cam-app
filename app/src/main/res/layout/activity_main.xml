<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Grid Container -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/cameraGrid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Control Bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="No cameras detected"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Scan"
            android:textSize="12sp"
            android:backgroundTint="#16213E"
            android:textColor="#4CC9F0"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:strokeColor="#4CC9F0"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnLayout"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Grid"
            android:textSize="12sp"
            android:backgroundTint="#16213E"
            android:textColor="#4CC9F0"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- Empty state overlay -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷"
            android:textSize="64sp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No USB Cameras Detected"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:text="Connect USB webcams to your Android device using a USB OTG adapter, then tap Scan."
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
